# Snippet for an existing server { } block on Ubuntu (e.g. sites-enabled).
# MCP Streamable HTTP: keep buffering off and long timeouts for streaming.
#
# Backend must use the same path (TRIMBLE_AGENTIC_MCP_PATH=/mcp/agent-studio)
# so the upstream receives /mcp/agent-studio as the request URI.
#
# Client URL: http://52.13.6.105/mcp/agent-studio

location /mcp/agent-studio {
    proxy_pass http://127.0.0.1:8305;
    proxy_http_version 1.1;
    # Forward real Host so MCP allowlist (TRIMBLE_AGENTIC_MCP_ALLOWED_HOSTS) can match.
    # Alternative: proxy_set_header Host 127.0.0.1:8305; if you do not set ALLOWED_HOSTS.
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    proxy_buffering off;
    proxy_read_timeout 86400s;
    proxy_send_timeout 86400s;
}
