# OAuth token minting for trimble-agentic-docs-refresh
# Copy to /etc/default/trimble-agentic-docs-refresh and chmod 600.

TRIMBLE_AGENTIC_SYNC_OAUTH_TOKEN_URL=https://stage.id.trimblecloud.com/oauth2/token
TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_ID=your_client_id
TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_SECRET=your_client_secret
TRIMBLE_AGENTIC_SYNC_OAUTH_SCOPE=openid agents tools models kb
# Optional: switch to refresh-token flow.
# TRIMBLE_AGENTIC_SYNC_OAUTH_GRANT_TYPE=refresh_token
# TRIMBLE_AGENTIC_SYNC_OAUTH_REFRESH_TOKEN=your_refresh_token
# Optional: OAuth provider tuning.
# TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_AUTH=body
# TRIMBLE_AGENTIC_SYNC_OAUTH_AUDIENCE=your_api_audience
# TRIMBLE_AGENTIC_SYNC_OAUTH_RESOURCE=your_resource
