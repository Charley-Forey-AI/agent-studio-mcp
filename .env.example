# Copy this file to `.env` at the repository root (same folder as README.md).
# `.env` is gitignored — never commit real secrets.
#
# Used automatically by:
#   trimble-agentic-openapi-sync  (python -m trimble_agentic_docs_mcp.sync_cli)
#   trimble-agentic-docs-refresh  (python -m trimble_agentic_docs_mcp.scheduler_runner)
#
# Existing environment variables always win over values in `.env`.

# --- Quick path: paste a short-lived TID access token (manual refresh when it expires) ---
# TRIMBLE_AGENTIC_SYNC_BEARER_TOKEN=your_tid_access_token

# --- Recommended: OAuth client credentials (trimble-agentic-docs-refresh mints a fresh bearer each run) ---
#
# IMPORTANT: Token issuer must match the portal in docs/urls.txt.
# - Syncing https://developer.stage.trimble-ai.com/... requires a STAGE token URL (below).
# - Using https://id.trimble.com/oauth/token (production) → tokens are rejected (401) by stage.
#
TRIMBLE_AGENTIC_SYNC_OAUTH_TOKEN_URL=https://stage.id.trimblecloud.com/oauth2/token
TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_ID=your_client_id
TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_SECRET=your_client_secret
TRIMBLE_AGENTIC_SYNC_OAUTH_SCOPE=openid agents tools models kb

# Optional: refresh-token grant instead of client_credentials
# TRIMBLE_AGENTIC_SYNC_OAUTH_GRANT_TYPE=refresh_token
# TRIMBLE_AGENTIC_SYNC_OAUTH_REFRESH_TOKEN=your_refresh_token

# Optional OAuth tuning (only if your IdP requires them)
# TRIMBLE_AGENTIC_SYNC_OAUTH_CLIENT_AUTH=body
# TRIMBLE_AGENTIC_SYNC_OAUTH_AUDIENCE=
# TRIMBLE_AGENTIC_SYNC_OAUTH_RESOURCE=
